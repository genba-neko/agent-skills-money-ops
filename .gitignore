


# =============================================================================
# workbench .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment files
# -----------------------------------------------------------------------------
.env

# -----------------------------------------------------------------------------
# Python virtual environments
# スタンドアロン使用時に生成される venv。
# -----------------------------------------------------------------------------
.venv-win/
.venv-wsl/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
*.egg-info/

# -----------------------------------------------------------------------------
# Runtime data
# スタンドアロン使用時に cleanup_rules / archive_rules が参照するディレクトリ。
# -----------------------------------------------------------------------------
#/data/
/logs/
/work/
/runtime/

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# ClaudeCode設定
# -----------------------------------------------------------------------------
.claude/skills*

# -----------------------------------------------------------------------------
# プロジェクト設定
# -----------------------------------------------------------------------------
# 作業用テンポラリ（git対象外・パスをプランやissueに記載禁止）
.work/
_*.txt

# -----------------------------------------------------------------------------
# データフォルダ設定
# -----------------------------------------------------------------------------
# データ・出力（個人情報を含むため絶対にコミット禁止）
# ディレクトリ構造保持用の .gitkeep のみコミット可
data/**
!data/**/
!data/**/.gitkeep
output/**
!output/.gitkeep
